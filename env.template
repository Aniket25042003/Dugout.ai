# Global Environment Variables Template for Dugout.ai
# Copy this to .env at the root or within specific services as needed.

# ==============================================================================
# Database Configuration (PostgreSQL)
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=dugout_admin
DB_PASSWORD=dugout_secret
DB_NAME=dugout
DB_SSLMODE=disable

# Database connection URL for migration tools & services
DATABASE_URL=postgres://dugout_admin:dugout_secret@localhost:5432/dugout?sslmode=disable

# ==============================================================================
# NATS Messaging Configuration
# ==============================================================================
NATS_URL=nats://localhost:4222
NATS_MONITORING_URL=http://localhost:8222

# ==============================================================================
# MediaMTX Configuration
# ==============================================================================
MEDIAMTX_RTSP_URL=rtsp://localhost:8554
MEDIAMTX_WEBRTC_URL=http://localhost:8889

# ==============================================================================
# Service Ports & Endpoints
# ==============================================================================
# event-gateway (Go)
EVENT_GATEWAY_PORT=8080
EVENT_GATEWAY_WS_URL=ws://localhost:8080/ws
EVENT_GATEWAY_SSE_URL=http://localhost:8080/events

# ai-orchestrator (Python FastAPI)
AI_ORCHESTRATOR_PORT=8000
AI_ORCHESTRATOR_URL=http://localhost:8000

# cv-node (Python Edge Node)
CV_NODE_PORT=8010
CV_NODE_CAMERA_RTSP_STREAM=rtsp://localhost:8554/home_plate_cam

# ==============================================================================
# Security & Auth Tokens (Placeholder for production setups)
# ==============================================================================
JWT_SECRET=super_secret_stadium_jwt_signing_token_change_me
REFEREE_AUTH_TOKEN=referee_pass_2026
MANAGER_AUTH_TOKEN=manager_pass_2026
